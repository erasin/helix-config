#!/usr/bin/env bash
#
# hx-desktop - Linux desktop entry 调用 helix
#
# 使用场景：通过桌面文件关联，在文件管理器中用 helix 打开文件
#
# 安装：
#   cp ~/dotfiles/helix/helix.desktop ~/.local/share/applications/
#
# desktop 文件配置：
#   Exec=/path/to/hx-desktop %f
#
# 参数：
#   文件路径    要打开的文件路径

selected_path=$1
[ -z "$selected_path" ] && { echo "错误：必须提供文件路径" >&2; exit 1; }

# 向上查找 .git 目录作为项目根目录
find_project_root() {
  local file="$1"
  local dir="$(dirname "$file")"

  for i in {0..5}; do
    if [ -d "$dir/.git" ]; then
      realpath "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done

  realpath "$(dirname "$file")"
}

# 查找项目根目录
project_root=$(find_project_root "$selected_path")

# 调用 hx-open 打开文件
exec hx-open "$project_root" "$selected_path"