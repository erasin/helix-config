#!/usr/bin/env bash
#
# ime-switch
#
# ln -s ~/dotfiles/helix/scripts/ime-switch ~/.local/bin/
# 
# 为 helix/vim 提供自动切换输入法
# esc 调用脚本切换为英文
# insert 自动返回为记录输入法
# 参数：
# 0 重置输入法为英文
# 1 返回记录的输入法
# 2 自动切换记录的输入法和英文输入

# window 可以使用 https://github.com/erasin/win-ime-switch
# macos 使用 macism 切换
# linux
#     ibus 使用 dbus
#     fcitx5 使用 fcitx5-remote

# 严格模式
set -euo pipefail

readonly ACTION="${1:-0}"
readonly KERNEL="$(uname)"

init_cache_file() {
    local cache_file="$1"
    mkdir -p "$(dirname "${cache_file}")" 2>/dev/null || true
    touch "${cache_file}"
}

read_cache() {
    local cache_file="$1"
    if [[ -f "${cache_file}" ]]; then
        cat "${cache_file}"
    fi
}

write_cache() {
    local cache_file="$1"
    local value="$2"
    echo "${value}" > "${cache_file}"
}

platform_osx() {
    local action="$1"
    local cache_file="${HOME}/.cache/ime-method-input"
    local method_en="com.apple.keylayout.ABC"
    local method_cn="im.rime.inputmethod.Squirrel.Hans"

    init_cache_file "${cache_file}"

    osx_get() {
        macism
    }

    osx_set() {
        macism "$1"
    }

    osx_en() {
        local current
        current=$(osx_get)
        if [[ "${current}" != "${method_en}" ]]; then
            osx_set "${method_en}"
            write_cache "${cache_file}" "${current}"
        else
            write_cache "${cache_file}" "${method_en}"
        fi
    }

    osx_re() {
        local current cached
        current=$(osx_get)
        cached=$(read_cache "${cache_file}")

        if [[ -n "${cached}" && "${cached}" != "${current}" ]]; then
            osx_set "${cached}"
        fi
    }

    osx_toggle() {
        local current
        current=$(osx_get)
        if [[ "${current}" != "${method_en}" ]]; then
            osx_set "${method_en}"
        else
            osx_set "${method_cn}"
        fi
    }

    case "${action}" in
        0) osx_en ;;
        1) osx_re ;;
        *) osx_toggle ;;
    esac
}

platform_ibus() {
    local action="$1"
    local cache_file="/tmp/ibus-method-input"
    local method_en="0|"
    local method_cn="1|小"

    init_cache_file "${cache_file}"

    ibus_get() {
        local cmd="dbus-send --session --type=method_call --print-reply=literal --dest=org.gnome.Shell /org/gnome/Shell/Extensions/IbusSwitcher org.gnome.Shell.Extensions.IbusSwitcher.CurrentSource"
        awk '{$1=$1};1' <<< "$(dbus-send --session --type=method_call --print-reply=literal --dest=org.gnome.Shell /org/gnome/Shell/Extensions/IbusSwitcher org.gnome.Shell.Extensions.IbusSwitcher.CurrentSource 2>/dev/null)"
    }

    ibus_set() {
        local id="${1%%|*}"
        local method="${1#*|}"
        dbus-send --session --type=method_call --print-reply=literal \
            --dest=org.gnome.Shell /org/gnome/Shell/Extensions/IbusSwitcher \
            org.gnome.Shell.Extensions.IbusSwitcher.SwitchSource \
            "uint32:${id}" "string:${method}" 2>/dev/null || true
    }

    ibus_en() {
        local current
        current=$(ibus_get)
        if [[ "${current}" != "${method_en}" ]]; then
            ibus_set "${method_en}"
            write_cache "${cache_file}" "${current}"
        else
            write_cache "${cache_file}" "${method_en}"
        fi
    }

    ibus_re() {
        local current cached
        current=$(ibus_get)
        cached=$(read_cache "${cache_file}")

        if [[ -n "${cached}" && "${cached}" != "${current}" ]]; then
            ibus_set "${cached}"
        fi
    }

    ibus_toggle() {
        local current
        current=$(ibus_get)
        if [[ "${current}" != "${method_en}" ]]; then
            ibus_set "${method_en}"
        else
            ibus_set "${method_cn}"
        fi
    }

    case "${action}" in
        0) ibus_en ;;
        1) ibus_re ;;
        *) ibus_toggle ;;
    esac
}

platform_fcitx5() {
    local action="$1"
    local cache_file="/tmp/fcitx5-method-input"
    local method_en="keyboard-us"
    local method_cn="rime"

    init_cache_file "${cache_file}"

    fcitx5_get() {
        fcitx5-remote -n
    }

    fcitx5_set() {
        fcitx5-remote -s "$1" 2>/dev/null || true
    }

    fcitx5_en() {
        local current
        current=$(fcitx5_get)
        if [[ "${current}" != "${method_en}" ]]; then
            fcitx5_set "${method_en}"
            write_cache "${cache_file}" "${current}"
        else
            write_cache "${cache_file}" "${method_en}"
        fi
    }

    fcitx5_re() {
        local current cached
        current=$(fcitx5_get)
        cached=$(read_cache "${cache_file}")

        if [[ -n "${cached}" && "${cached}" != "${current}" ]]; then
            fcitx5_set "${cached}"
        fi
    }

    fcitx5_toggle() {
        local current
        current=$(fcitx5_get)
        if [[ "${current}" != "${method_en}" ]]; then
            fcitx5_set "${method_en}"
        else
            fcitx5_set "${method_cn}"
        fi
    }

    case "${action}" in
        0) fcitx5_en ;;
        1) fcitx5_re ;;
        *) fcitx5_toggle ;;
    esac
}

platform_wsl() {
    local action="$1"
    case "${action}" in
        0) win-ime-switch.exe en ;;
        *) win-ime-switch.exe --toggle ;;
    esac
}

main() {
    case "${KERNEL}" in
        Darwin)
            platform_osx "${ACTION}"
            ;;
        Linux)
            if [[ -n "${WSL_DISTRO_NAME:-}" ]]; then
                platform_wsl "${ACTION}"
            elif command -v fcitx5-remote &>/dev/null; then
                platform_fcitx5 "${ACTION}"
            elif command -v ibus &>/dev/null; then
                platform_ibus "${ACTION}"
            else
                echo "无可用的输入法系统" >&2
                exit 1
            fi
            ;;
        *)
            echo "不支持的系统: ${KERNEL}" >&2
            exit 1
            ;;
    esac
}

main
